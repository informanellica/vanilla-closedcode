{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.14.33",
  "name": "closedcode",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --testTimeout 30000",
    "test:ci": "mkdir -p .artifacts/unit && NODE_OPTIONS='--experimental-vm-modules' jest --testTimeout 30000 --reporters=default --reporters=jest-junit",
    "test:leaks": "JEST_NO_FORCE_EXIT=1 NODE_OPTIONS='--experimental-vm-modules' jest --testTimeout 30000 --detectOpenHandles --runInBand",
    "build": "node script/build.js",
    "fix-node-pty": "node script/fix-node-pty.js",
    "upgrade-opentui": "node script/upgrade-opentui.js",
    "dev": "NODE_OPTIONS='--conditions=browser' node ./src/index.js",
    "dev:temporary": "NODE_OPTIONS='--conditions=browser' node ./src/temporary.js",
    "db": "npx drizzle-kit"
  },
  "bin": {
    "closedcode": "./bin/closedcode"
  },
  "exports": {
    "./*": "./src/*.js"
  },
  "imports": {
    "#db": {
      "node": "./src/storage/db.node.js",
      "default": "./src/storage/db.node.js"
    },
    "#pty": {
      "node": "./src/pty/pty.node.js",
      "default": "./src/pty/pty.node.js"
    },
    "#tui/*": "./src/cli/cmd/tui/*",
    "#*": "./src/*"
  },
  "devDependencies": {
    "@babel/core": "7.28.4",
